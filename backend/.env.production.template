# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# ⚠️  SECURITY WARNING: Never commit this file with real credentials to git
# Instructions: Copy this to .env and fill in all production values
# ============================================================================

# ============================================================================
# MongoDB Atlas - Production Database
# ============================================================================
# Get connection string from MongoDB Atlas dashboard
# Use PRODUCTION database (cnstoolsandrepair_db_prod), not dev database
MONGODB_URL=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/<DATABASE>?retryWrites=true&w=majority&tls=true
DATABASE_NAME=cnstoolsandrepair_db_prod

# ============================================================================
# CORS - Production Domains Only
# ============================================================================
# Replace with your actual production domain(s)
# Multiple domains: https://example.com,https://www.example.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# Email - SendGrid Configuration
# ============================================================================
# Get API key from SendGrid dashboard (use production key)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@cnstoolrepair.com
NOTIFICATION_EMAIL=cnstoolrepair@gmail.com

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
UPLOAD_DIR=uploads
# Production: Use Spaces CDN URL, not localhost
UPLOAD_BASE_URL=https://cnstoolsandrepair-photos.nyc3.cdn.digitaloceanspaces.com

# ============================================================================
# Digital Ocean Spaces - REQUIRED for Production
# ============================================================================
# ⚠️  CRITICAL: Set USE_SPACES=true in production to avoid file loss on container restart
USE_SPACES=true
SPACES_REGION=nyc3
SPACES_BUCKET=cnstoolsandrepair-photos
# Get access key and secret from Digital Ocean Spaces dashboard (API section)
SPACES_KEY=DO00XXXXXXXXXXXXXXXXX
SPACES_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ============================================================================
# Environment Setting
# ============================================================================
# Must be 'production' to enable security features (CSRF cookie_secure, etc.)
ENVIRONMENT=production

# ============================================================================
# JWT Authentication
# ============================================================================
# ⚠️  CRITICAL: Generate NEW secret key for production (different from dev)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_MINIMUM_32_CHARACTERS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# ============================================================================
# Production Checklist
# ============================================================================
# Before deploying, verify:
# ✅ MongoDB URL points to PRODUCTION database (not dev)
# ✅ CORS_ORIGINS uses HTTPS production domain (not localhost)
# ✅ USE_SPACES=true and Spaces credentials are valid
# ✅ JWT_SECRET_KEY is unique and different from development
# ✅ SendGrid API key is for production account
# ✅ ENVIRONMENT=production
# ✅ This file is NOT committed to git (check .gitignore)
# ============================================================================
